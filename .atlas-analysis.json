  "keyFeatures": [
    "Full RFC 5245 ICE protocol implementation",
    "Support for UDP and TCP candidates",
    "STUN and TURN server integration",
    "NAT traversal with multiple candidate types",
    "Connection multiplexing (UDPMux, TCPMux)",
    "mDNS support for local network discovery",
    "Configurable gathering and connectivity policies",
    "Automatic and continual candidate gathering",
    "Renomination support for connection migration",
    "Comprehensive statistics and monitoring"
  ],
